{
	"name": "@incandescent/scripts",
	"version": "0.1.0",
	"description": "A set of scripts that we use for our workflows",
	"private": true,
	"scripts": {
		"build": "tsup",
		"lint": "prettier --check . && eslint src --ext .mjs,.js,.ts --format=pretty",
		"format": "prettier --write . && eslint src --ext .mjs,.js,.ts --fix --format=pretty"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		"import": "./dist/index.mjs",
		"require": "./dist/index.js",
		"types": "./dist/index.d.ts"
	},
	"directories": {
		"lib": "src"
	},
	"files": [
		"dist"
	],
	"author": "Craftinators",
	"license": "Apache-2.0",
	"keywords": [
		"nodejs",
		"npm",
		"typescript"
	],
	"homepage": "https://github.com/Craftinators/incandescent#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/Craftinators/incandescent.git"
	},
	"bugs": {
		"url": "https://github.com/Craftinators/incandescent/issues"
	},
	"devDependencies": {
		"@types/node": "^18.16.3",
		"eslint": "^8.39.0",
		"eslint-config-neon": "^0.1.42",
		"eslint-formatter-pretty": "^5.0.0",
		"prettier": "^2.8.8",
		"tsup": "^6.7.0",
		"typescript": "^5.0.4"
	},
	"dependencies": {
		"incandescent": "workspace:0.2.0-mono"
	}
}
